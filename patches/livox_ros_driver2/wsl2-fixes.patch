+void PubHandler::MaybeLogHeartbeat() {
+  const auto now = std::chrono::high_resolution_clock::now();
+  if (last_heartbeat_time_.time_since_epoch().count() == 0) {
+    last_heartbeat_time_ = now;
+    return;
+  }
+
+  const auto elapsed = std::chrono::duration_cast<std::chrono::milliseconds>(
+      now - last_heartbeat_time_);
+  if (elapsed < kHeartbeatInterval) {
+    return;
+  }
+
+  const uint64_t point_packets = point_packets_received_.load(std::memory_order_relaxed);
+  const uint64_t imu_packets = imu_packets_received_.load(std::memory_order_relaxed);
+  const uint64_t published_frames = frames_published_.load(std::memory_order_relaxed);
+  const uint64_t published_points = points_published_.load(std::memory_order_relaxed);
+
+  std::cout << "[LIVOX] heartbeat " << (elapsed.count() / 1000.0) << "s"
+            << " rx(point=" << (point_packets - last_heartbeat_point_packets_)
+            << ", imu=" << (imu_packets - last_heartbeat_imu_packets_)
+            << ") pub(frames=" << (published_frames - last_heartbeat_frames_published_)
+            << ", points=" << (published_points - last_heartbeat_points_published_)
+            << ") queue=" << raw_packet_queue_.size()
+            << " lidars=" << lidar_process_handlers_.size()
+            << std::endl;
+
+  last_heartbeat_time_ = now;
+  last_heartbeat_point_packets_ = point_packets;
+  last_heartbeat_imu_packets_ = imu_packets;
+  last_heartbeat_frames_published_ = published_frames;
+  last_heartbeat_points_published_ = published_points;
+}
